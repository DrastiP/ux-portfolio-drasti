---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Spur | Case Study">
	<main class="max-w-3xl mx-auto px-6 pt-24 pb-32">
		<a href="/ux-portfolio-drasti/" class="text-sm font-medium text-slate-500 hover:text-blue-600 transition-colors mb-12 block">
			← Back to Work
		</a>
		
		<header class="mb-16">
			<p class="text-blue-600 font-bold tracking-wide uppercase text-sm mb-4">eCommerce Store</p>
			<h1 class="text-5xl font-bold leading-tight mb-8">Spur: Local Artisans, Global Reach</h1>
			<div class="grid grid-cols-2 md:grid-cols-4 gap-8 py-8 border-y border-slate-100">
				<div>
					<p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Role</p>
					<p class="text-sm font-medium">Visual Designer</p>
				</div>
				<div>
					<p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Timeline</p>
					<p class="text-sm font-medium">2 Months</p>
				</div>
				<div>
					<p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Platform</p>
					<p class="text-sm font-medium">Mobile App</p>
				</div>
				<div>
					<p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Read Time</p>
					<p class="text-sm font-medium">5 min</p>
				</div>
			</div>
		</header>

		<section class="prose prose-slate max-w-none space-y-12">
			<div>
				<h2 class="text-2xl font-bold mb-4">The Challenge</h2>
				<p class="text-lg text-slate-600 leading-relaxed">
					Local artisans lacked a platform to sell their goods that felt as personalized as their craft. 
					Generic eCommerce sites stripped away the "soul" of their work.
				</p>
			</div>

			<div class="aspect-[16/9] bg-slate-50 rounded-3xl overflow-hidden border border-slate-100 flex items-center justify-center text-slate-300 italic">
				Hero Image Placeholder: Spur Mobile Interface
			</div>

			<div>
				<h2 class="text-2xl font-bold mb-4">The Solution</h2>
				<p class="text-lg text-slate-600 leading-relaxed">
					We built a storytelling-first eCommerce app that prioritizes the artist's process, 
					making every purchase feel like a direct connection between creator and buyer.
				</p>
			</div>
		</section>
	</main>
</Layout>
