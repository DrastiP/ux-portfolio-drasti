---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/ux-portfolio-drasti/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Drasti Patel</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-white text-slate-900 font-['Inter',sans-serif] selection:bg-blue-100">
		<nav class="max-w-5xl mx-auto px-6 py-8 flex justify-between items-center">
			<a href={import.meta.env.BASE_URL} class="text-xl font-bold tracking-tight">DP.</a>
			<div class="space-x-8 text-sm font-medium text-slate-600">
				<a href={`${import.meta.env.BASE_URL}#work`} class="hover:text-blue-600 transition-colors">Work</a>
				<a href={`${import.meta.env.BASE_URL}#about`} class="hover:text-blue-600 transition-colors">About</a>
				<a href={`${import.meta.env.BASE_URL}resume.pdf`} class="hover:text-blue-600 transition-colors">Resume</a>
			</div>
		</nav>
		<slot />
		<footer class="max-w-5xl mx-auto px-6 py-12 text-sm text-slate-400">
			© {new Date().getFullYear()} Drasti Patel. Built with Astro & Tailwind CSS.
		</footer>
	</body>
</html>
